apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: postgres
  annotations:
    config.kubernetes.io/local-config: "true"
upstream:
  type: git
  git:
    repo: https://github.com/LCOGT/kpt-pkg-catalog
    directory: /helm-chart
    ref: main
  updateStrategy: resource-merge
upstreamLock:
  type: git
  git:
    repo: https://github.com/LCOGT/kpt-pkg-catalog
    directory: /helm-chart
    ref: main
    commit: 6ae2417d130bf1ae275cc52a65d8db3e90a12da6
pipeline:
  mutators:
    - image: gcr.io/kpt-fn/apply-replacements:v0.1.1
      configPath: ./fn-replacements.yaml
      name: apply-replacements
    - image: gcr.io/kpt-fn/render-helm-chart:v0.2.2
      configPath: ./charts.yaml
      name: render-helm-chart
    - image: gcr.io/kpt-fn/starlark:v0.5.0
      configMap:
        source: |-
          output = "rendered.yaml"
          for i, r in enumerate(ctx.resource_list["items"]):
            if r.get("metadata", {}).get("annotations", {}).get("internal.config.kubernetes.io/path", "") == output:
              continue

            r["metadata"]["annotations"]["internal.config.kubernetes.io/path"] = output
            r["metadata"]["annotations"]["internal.config.kubernetes.io/index"] = "%d" % i
      name: output-to-file
      exclude:
        - kind: RenderHelmChart
        - kind: Kptfile
        - kind: Kustomization
        - kind: ApplyReplacements
